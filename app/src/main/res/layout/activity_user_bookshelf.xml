<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_bg"
    android:orientation="vertical"
    android:padding="8dp"> <!-- 根布局添加轻微内边距，避免控件贴边 -->

    <!-- 标题栏：增强视觉层次，添加阴影和圆角 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center"
        android:text="用户书架查看"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="@drawable/admin_title_bg"
        android:layout_marginBottom="12dp"
        android:elevation="3dp" />

    <!-- Spinner：美化样式，统一圆角风格 -->
    <Spinner
        android:id="@+id/sp_users"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingHorizontal="15dp"
        android:paddingVertical="8dp"
        android:background="@drawable/admin_spinner_bg"
        android:layout_marginBottom="10dp"
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center_vertical" />

    <!-- ListView：添加分隔线、圆角，优化滚动体验 -->
    <ListView
        android:id="@+id/lv_user_books"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/admin_listview_bg"
        android:divider="@color/colorDivider"
        android:dividerHeight="0.8dp"
        android:padding="2dp"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbars="vertical" />

</LinearLayout>