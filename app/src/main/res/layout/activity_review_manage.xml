<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/admin_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/admin_title_bg"
        android:elevation="3dp"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:text="用户书评管理"
        android:textColor="@android:color/white"
        android:textSize="18sp" />

    <!-- 添加用户选择下拉框 -->
    <Spinner
        android:id="@+id/sp_users"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingHorizontal="15dp"
        android:paddingVertical="8dp"
        android:background="@drawable/admin_spinner_bg"
        android:layout_marginBottom="10dp"
        android:textSize="16sp"
        android:gravity="center_vertical" />

    <ListView
        android:id="@+id/lv_all_reviews"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/admin_listview_bg"
        android:divider="@color/colorDivider"
        android:dividerHeight="0.8dp"
        android:padding="2dp" />

</LinearLayout>